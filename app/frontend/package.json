{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"NEXT,GO,AI-RUST,AI-GO\" -c \"cyan,magenta,green,blue\" \"npm:dev:next\" \"npm:dev:go\" \"npm:dev:ai:rust\" \"npm:dev:ai:go\"",
    "dev:next": "next dev -p 4000",
    "dev:go": "cd src/app/server/go && go run main.go",
    "dev:ai:data": "python src/app/game/components/AI_logic/8_geopolitik_advanced/scripts/data_generator.py",
    "dev:ai:rust": "cd src/app/game/components/AI_logic/8_geopolitik_advanced/core_engine && cargo run --release",
    "dev:ai:go": "cd src/app/game/components/AI_logic/8_geopolitik_advanced/backend && go run api_gateway.go",
    "setup": "npm install && npm run dev:ai:data && npm run dev",
    "build": "next build",
    "build:workers": "rustc src/app/server/rust/main.rs -o src/app/server/rust/worker.exe",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-zoom-pan-pinch": "^3.7.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "postcss": "^8.4.47",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
