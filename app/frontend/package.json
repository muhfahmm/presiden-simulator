{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build:workers && concurrently -n \"NEXT,GO\" -c \"cyan,magenta\" \"npm:dev:next\" \"npm:dev:go\"",
    "dev:next": "next dev -p 4000",
    "dev:go": "go run src/app/server/go/main.go src/app/server/go/inbox.go",
    "build": "next build",
    "build:workers": "g++ src/app/server/cpp/main.cpp -o src/app/server/cpp/worker.exe && rustc src/app/server/rust/main.rs -o src/app/server/rust/worker.exe",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-zoom-pan-pinch": "^3.7.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "postcss": "^8.4.47",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
