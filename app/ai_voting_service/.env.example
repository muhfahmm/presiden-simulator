# AI Voting Service Configuration

# Service Port
PORT=8000

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: OpenAI API Key (untuk future LLM integration)
# OPENAI_API_KEY=your_api_key_here

# Optional: Model Configuration
# AI_MODEL=gpt-4
# AI_TEMPERATURE=0.7

# Logging
LOG_LEVEL=INFO
